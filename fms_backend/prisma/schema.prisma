// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  username        String?         @unique
  email           String?         @unique
  passwordHash    String?
  role            Role
  
  // Role-specific relationships
  manager         Manager?
  driver          Driver?
  maintenance     Maintenance?
  
  // Audit trail
  createdUsers    User[]          @relation("UserCreatedUsers")
  createdById     String?
  createdBy       User?           @relation("UserCreatedUsers", fields: [createdById], references: [id])
  createdVehicles Vehicle[]       @relation("UserCreatedVehicles")
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Manager {
  id              String          @id @default(cuid())
  name            String
  phone           String?         @unique
  address         String?
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Driver {
  id              String          @id @default(cuid())
  name            String
  phone           String?         @unique
  address         String?
  email           String?         @unique
  licenceNumber   String?         @unique
  expiryDate      String?
  classes         String[]
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Maintenance {
  id              String          @id @default(cuid())
  name            String
  phone           String?         @unique
  address         String?
  email           String?         @unique
  certification   String?
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Vehicle {
  id              String    @id @default(cuid())
  ownerName       String
  vehicleModel    String
  registrationNum String    @unique
  chassisNum      String    @unique
  odometerReading String
  createdById     String?
  createdBy       User?     @relation("UserCreatedVehicles", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum Role {
  SUPER_ADMIN
  MANAGER
  DRIVER
  MAINTENANCE
}

enum VehiclesAllowed {
  MCWG
  LMV
  MVSD
}
